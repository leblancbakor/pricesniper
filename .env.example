# Copy this file to `.env` and fill in real values. `.env` is gitignored, so
# your secrets never get committed.

# Discord bot token, from the Discord Developer Portal (Bot tab).
DISCORD_BOT_TOKEN=

# Discord channel ID to post alerts into. Enable Developer Mode in Discord,
# then right-click the channel and choose "Copy Channel ID".
DISCORD_CHANNEL_ID=

# Database location. Starts as SQLite; the path is created automatically.
DATABASE_URL=sqlite:///data/pricesniper.db
